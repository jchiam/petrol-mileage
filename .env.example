# ── Database credentials (used by docker-compose and the app) ─────────────────
# Required — set a strong password before first deploy
POSTGRES_USER=petrol
POSTGRES_PASSWORD=changeme
POSTGRES_DB=petrol_mileage

# ── Backup sidecar ────────────────────────────────────────────────────────────
# Absolute path on the NAS host where .sql.gz backup files are written
BACKUP_DIR=/volume1/docker/petrol-tracker/backups

# ── App database connection ───────────────────────────────────────────────────
# Production (inside Docker): hostname is "db" (the compose service name)
# DATABASE_URL=postgresql://petrol:changeme@db:5432/petrol_mileage
#
# Local development (npm run dev on host): hostname is localhost, port forwarded
# via docker-compose.dev.yml
DATABASE_URL=postgresql://petrol:changeme@localhost:5432/petrol_mileage
